APP_ENV=local
APP_URL=http://localhost:8080
SITE_URL=http://localhost:3000
URI_ALLOW_LIST=http://localhost:3000/*

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=maludb_auth
DB_USER=postgres
DB_PASSWORD=postgres

# Integration test DB (must be a throwaway database)
TEST_DB_NAME=maludb_auth_test

JWT_ISSUER=http://localhost:8080/auth/v1
JWT_AUDIENCE=authenticated
JWT_EXP=3600
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_KID=key-1

REFRESH_TOKEN_TTL=2592000          # 30 days (inactivity window)
REFRESH_TOKEN_REUSE_INTERVAL=10    # seconds
SESSION_TIMEBOX=0                   # 0 = disabled (absolute max lifetime in seconds)
SESSION_INACTIVITY_TIMEOUT=0       # 0 = disabled

PASSWORD_MIN_LENGTH=12
DISABLE_SIGNUP=false
MAILER_AUTOCONFIRM=true            # false = signup requires emailed confirmation

COOKIE_SECURE=false                # true in prod
COOKIE_SAMESITE=Lax

# One-time tokens (confirmation / recovery / magiclink / invite / reauth)
OTP_TTL=3600                       # seconds a mailed code or link stays valid

# Outbound mail. 'log' writes to error_log (DEV ONLY: bodies contain live
# one-time codes); 'null' drops mail. Production wires a real MailerInterface.
MAILER_DRIVER=log
MAILER_FROM=auth@localhost

# Require a fresh reauthentication nonce (POST /reauthenticate -> emailed code,
# passed as `nonce`) for PUT /user password changes.
UPDATE_PASSWORD_REQUIRE_REAUTHENTICATION=false

# Shared secret authorizing /auth/v1/admin/* endpoints (sent as the apikey or
# Authorization header). Alternatively, mint a service-role JWT (role:service_role)
# with bin/issue-service-token.php. Keep this secret out of client bundles.
SERVICE_ROLE_KEY=
